# Copie este arquivo para .env e preencha os valores.
# No Railway/Render, configure estas variaveis diretamente no painel.

# Banco de dados
# Dev local (SQLite):
DATABASE_URL=sqlite+aiosqlite:///./govmatch.db
# Producao (PostgreSQL - Railway fornece esta URL automaticamente):
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Log
LOG_LEVEL=INFO
