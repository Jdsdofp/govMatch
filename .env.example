DATABASE_URL=sqlite+aiosqlite:///./govmatch.db
# Para PostgreSQL em produção:
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/govmatch

PNCP_BASE_URL=https://pncp.gov.br/api/pncp/v1
COMPRAS_GOV_URL=https://compras.gov.br

# Tesseract (Windows: ajustar caminho)
TESSERACT_CMD=tesseract
# TESSERACT_CMD=C:/Program Files/Tesseract-OCR/tesseract.exe

# Diretório temporário para PDFs baixados
PDF_DOWNLOAD_DIR=./tmp/pdfs

# Intervalo de sync automático em segundos (0 = desativado)
SYNC_INTERVAL_SECONDS=3600

LOG_LEVEL=INFO
